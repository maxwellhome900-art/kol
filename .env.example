# Optional: Discord incoming webhook URL so client chat alerts hit your phone/desktop Discord.
# Create: Discord server → Channel → Edit → Integrations → Webhooks → New Webhook → copy URL
# Deploy: paste the same value in your host’s environment variables (e.g. Vercel Project Settings → Environment Variables)
DISCORD_WEBHOOK_URL=

# --- Intelligent hold alerts (POST /api/booking-notify after Confirm) ---
# Email via Resend (https://resend.com): create API key + verify sending domain; set a From address on that domain.
RESEND_API_KEY=
RESEND_FROM=
# Optional: override inbox for hold emails (defaults to site.email in src/lib/data.ts)
BOOKING_INBOX_EMAIL=
# Hold summaries also post to DISCORD_WEBHOOK_URL when set (same variable as Marko chat in contact-notify).
